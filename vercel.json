{
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "includeFiles": [
                    "app/**",
                    "bootstrap/**",
                    "config/**",
                    "database/**",
                    "lang/**",
                    "resources/**",
                    "routes/**",
                    "storage/**",
                    "vendor/**",
                    "public_html/**",
                    "composer.json",
                    "composer.lock",
                    "artisan"
                ]
            }
        },
        {
            "src": "public_html/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/public_html/build/$1" },
        { "src": "/favicon.ico", "dest": "/public_html/favicon.ico" },
        { "src": "/robots.txt", "dest": "/public_html/robots.txt" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ]
}
